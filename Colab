def stream_quantum_heatmap(boundary_size=2500, matrix_dim=80, max_frames_to_generate=10, save_data_as_txt=False):
    global reset_requested
    anchor = get_invariant_anchor()
    internal_scale = 1.0 / boundary_size
    x_s = np.linspace(-matrix_dim//2, matrix_dim//2, matrix_dim) * internal_scale
    X, Y = np.meshgrid(x_s, x_s)
    R = np.sqrt(X**2 + Y**2) + 1e-9
    t = 0.0
    next_soliton_t = 0.0 # Modified to make solitons appear earlier
    solitons = []
    t_hist, center_hist = [], []
    frame_counter = 0 # Initialize frame counter

    try:
        while True:
            while paused: time.sleep(0.1)
            if reset_requested:
                t, next_soliton_t = 0.0, 0.0 # Modified here too for reset
                solitons.clear(); t_hist.clear(); center_hist.clear()
                reset_requested = False
                frame_counter = 0 # Reset frame counter as well

            if t >= next_soliton_t:
                solitons.append({'spawn_time': t, 'angle': np.random.uniform(0, 2*np.pi)})
                next_soliton_t += 0.1 # Make solitons appear more frequently

            phase = (t * internal_scale * (anchor / 100.0)) / R
            alpha = np.cos(phase) + 1j * np.sin(phase)
            beta = np.sin(phase) - 1j * np.cos(phase)

            # Baseline Flow
            flow = np.abs(alpha * beta) / np.sqrt(np.abs(alpha)**2 + np.abs(beta)**2)

            for sol in solitons[:]:
                dt = t - sol['spawn_time']
                r_sol = dt * (20.0 * internal_scale)
                dist = np.sqrt((X - r_sol*np.cos(sol['angle']))**2 + (Y - r_sol*np.sin(sol['angle']))**2)
                flow += 2.5 * np.exp(-(dist**2) / ((4.0*internal_scale)**2))
                if r_sol >= (matrix_dim * internal_scale): solitons.remove(sol)

            t_hist.append(t); center_hist.append(flow[matrix_dim//2, matrix_dim//2])
            if len(t_hist) > 200: t_hist.pop(0); center_hist.pop(0)

            clear_output(wait=True)
            fig, ax = plt.subplots(1, 2, figsize=(16, 5))

            # High-intensity soliton mapping against baseline Flow
            ax[0].imshow(flow, cmap='inferno', extent=[-matrix_dim//2, matrix_dim//2, -matrix_dim//2, matrix_dim//2], vmax=3.0)
            ax[0].set_title(f"NELOS Live Synthetic Quantum Matrix\nTime: {t:.2f} | Solitons: {len(solitons)}", fontweight='bold')
            ax[0].set_xlabel("Coordinate Horizon Axis (X)")
            ax[0].set_ylabel("Coordinate Horizon Axis (Y)")

            ax[1].plot(t_hist, center_hist, color='cyan')
            ax[1].set_title('Central Flow (Oscilloscope)')
            ax[1].set_xlabel('Time (t)')
            ax[1].set_ylabel('Central Flow Intensity')
            ax[1].grid(True, linestyle='--', alpha=0.7)
            ax[1].set_ylim(0, 3.5)

            plt.tight_layout()

            # Save each frame with a unique name BEFORE showing or closing
            fig.savefig(f'quantum_heatmap_frame_{frame_counter+1:02d}.png')

            # Removed plt.show() and plt.close(fig) from the loop to avoid interference with savefig

            # Save numerical data as text file if requested
            if save_data_as_txt:
                data_filename = f'quantum_heatmap_data_frame_{frame_counter+1:02d}.txt'
                np.savetxt(data_filename, flow)
                print(f"Saved numerical data for frame {frame_counter+1} to {data_filename}")

            frame_counter += 1
            if frame_counter >= max_frames_to_generate:
                break # Exit the loop after showing the required number of frames

            t += 0.05
            time.sleep(frame_delay_slider.value)
    except KeyboardInterrupt:
        pass

    # No need for a final save block, as frames are saved within the loop
    print(f"Generated {max_frames_to_generate} frames and saved them as quantum_heatmap_frame_XX.png")
    if save_data_as_txt:
        print(f"Also saved numerical data for {max_frames_to_generate} frames as quantum_heatmap_data_frame_XX.txt")

